# ===================================
# Docker Environment Configuration
# ===================================
# Copy this file to .env and update with your production values

# MySQL Database Configuration
MYSQL_DATABASE=ecommerce
MYSQL_ROOT_PASSWORD=root123_change_this_in_production
MYSQL_USER=appuser
MYSQL_PASSWORD=apppass123_change_this_in_production
MYSQL_PORT=3306

# Spring Boot Application Configuration
APP_PORT=8080
SPRING_PROFILES_ACTIVE=prod
DDL_AUTO=update
SHOW_SQL=false
FORMAT_SQL=false

# JWT Security Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
JWT_EXPIRATION=3600000

# Timezone Configuration
TZ=Asia/Ho_Chi_Minh

# Logging Configuration
LOG_LEVEL=INFO

# Database Connection Pool
DB_POOL_SIZE=20
DB_MIN_IDLE=5

# Java Virtual Machine Options
JAVA_OPTS=-Xmx512m -Xms256m -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# ===================================
# SECURITY NOTES:
# ===================================
# 1. Change all passwords in production!
# 2. Use strong JWT_SECRET (min 32 chars)
# 3. Never commit .env file to version control
# 4. Keep .env in .gitignore
# 5. Use environment-specific .env files
# 6. Rotate JWT_SECRET periodically
# 1. Never commit .env file to Git
# 2. Use strong passwords in production
# 3. Change default passwords before deployment

